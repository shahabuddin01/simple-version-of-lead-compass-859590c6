# NH Production House CRM — Environment Variables
# Copy this file to .env and fill in the values

# App Configuration — change this to your domain when deploying
VITE_APP_URL=https://shortcaptionbangla.com

# Backend API URL — same as APP_URL for cPanel hosting
# (the PHP backend lives at /backend/api/ on the same domain)
VITE_API_URL=https://shortcaptionbangla.com

# MillionVerifier API Key (optional — for email verification)
VITE_MILLIONVERIFIER_API_KEY=your_millionverifier_key

# Google Drive OAuth (optional — for Drive backup integration)
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# CRM API Connection (for importing leads from external CRM)
VITE_CRM_API_URL=https://[project-ref].supabase.co/rest/v1
VITE_CRM_API_KEY=your_read_only_api_key_from_crm
