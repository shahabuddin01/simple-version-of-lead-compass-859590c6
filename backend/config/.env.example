# NH Production House CRM — Backend Environment Variables
# Copy this to .env and fill in your cPanel database credentials

DB_HOST=localhost
DB_NAME=your_cpanel_db_name
DB_USER=your_cpanel_db_user
DB_PASS=your_cpanel_db_password
